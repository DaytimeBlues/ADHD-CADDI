# ============================================================================
# Environment Variables - ADHD-CADDI
# ============================================================================
# Copy this file to .env for local development.
#
# IMPORTANT:
# - Variables prefixed with EXPO_PUBLIC_ are bundled into the client.
# - Treat them as public values, not secrets.
# - Real secrets should live in server-side env vars or CI secrets.
# ============================================================================

# Runtime environment
# EXPO_PUBLIC_ENV=development

# API base URL used by web/native clients for backend requests
# EXPO_PUBLIC_API_BASE_URL=https://spark-adhd-api.vercel.app

# Google OAuth client IDs (public identifiers)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Sentry DSN (public ingest DSN; safe to expose in client bundles)
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# AI settings
# Keep production on the server-backed provider.
# EXPO_PUBLIC_AI_PROVIDER=vercel
# EXPO_PUBLIC_AI_TIMEOUT=8000
# EXPO_PUBLIC_AI_MAX_RETRIES=3
# EXPO_PUBLIC_KIMI_MODEL=kimi-k2.5

# Insecure direct AI keys (development only; never for production Pages/mobile builds)
# EXPO_PUBLIC_ENABLE_INSECURE_DIRECT_AI=false
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_MOONSHOT_API_KEY=

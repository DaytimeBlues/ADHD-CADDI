# ============================================================================
# Environment Variables — ADHD-CADDI
# ============================================================================
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the web client
# by webpack's DefinePlugin (see webpack.config.js).
# ============================================================================

# --- Google OAuth (required for Google Tasks sync) ---
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# --- AI / LLM Services (optional — used by FogCutterAIService, ChatService) ---
# EXPO_PUBLIC_AI_API_KEY=your-api-key
# EXPO_PUBLIC_AI_BASE_URL=https://api.example.com/v1

# --- Sentry Error Tracking (optional — production only) ---
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
